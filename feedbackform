/* index.html*/
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elegant Feedback Form</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="background-shape shape-one"></div>
    <div class="background-shape shape-two"></div>

    <div class="page">
        <div class="form-card">
            <div class="header">
                <span class="tag">We'd Love to Hear From You</span>
                <h1>Feedback Form</h1>
                <p>Your opinion helps us grow, improve, and create a better experience every day.</p>
            </div>

            <form id="feedbackForm" class="feedback-form">
                <div class="row">
                    <div class="input-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="Enter your full name" required>
                    </div>

                    <div class="input-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="Enter your email" required>
                    </div>
                </div>

                <div class="input-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" placeholder="Enter your phone number">
                </div>

                <div class="input-group">
                    <label for="category">Feedback Category</label>
                    <select id="category" name="category" required>
                        <option value="">Select a category</option>
                        <option>Website Experience</option>
                        <option>Service Quality</option>
                        <option>Product Quality</option>
                        <option>Support Team</option>
                        <option>General Suggestion</option>
                    </select>
                </div>

                <div class="input-group">
                    <label>How would you rate your experience?</label>
                    <div class="radio-group">
                        <label><input type="radio" name="rating" value="Excellent" required> Excellent</label>
                        <label><input type="radio" name="rating" value="Good"> Good</label>
                        <label><input type="radio" name="rating" value="Average"> Average</label>
                        <label><input type="radio" name="rating" value="Poor"> Poor</label>
                    </div>
                </div>

                <div class="input-group">
                    <label for="recommend">Would you recommend us to others?</label>
                    <select id="recommend" name="recommend" required>
                        <option value="">Choose an option</option>
                        <option>Yes</option>
                        <option>No</option>
                        <option>Maybe</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="message">Your Feedback</label>
                    <textarea id="message" name="message" rows="6" placeholder="Write your valuable feedback here..." required></textarea>
                </div>

                <label class="checkbox-row">
                    <input type="checkbox" id="confirmCheck" required>
                    <span>I confirm that the information provided is correct.</span>
                </label>

                <div class="button-group">
                    <button type="submit" class="btn submit-btn">Submit Feedback</button>
                    <button type="reset" class="btn reset-btn">Reset Form</button>
                </div>
            </form>
        </div>
    </div>

    <div class="popup-overlay" id="successPopup">
        <div class="popup-card">
            <div class="popup-icon">✓</div>
            <h2>Congratulations!</h2>
            <p>Your feedback form has been submitted successfully.</p>
            <p class="popup-line">Thank you for sharing your thoughts — every response helps us serve you better.</p>
            <button class="popup-btn" onclick="closePopup()">OK</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>


/*CSS Style*/
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, Helvetica, sans-serif;
    min-height: 100vh;
    color: #1e293b;
    background: linear-gradient(135deg, #dbeafe, #eff6ff, #e0f2fe);
    position: relative;
    overflow-x: hidden;
}

.background-shape {
    position: fixed;
    border-radius: 50%;
    filter: blur(20px);
    opacity: 0.4;
    z-index: 0;
}

.shape-one {
    width: 250px;
    height: 250px;
    background: #93c5fd;
    top: 40px;
    left: 40px;
}

.shape-two {
    width: 300px;
    height: 300px;
    background: #bfdbfe;
    bottom: 40px;
    right: 40px;
}

.page {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 35px 15px;
    position: relative;
    z-index: 1;
}

.form-card {
    width: 100%;
    max-width: 860px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.14);
    padding: 38px;
    border: 1px solid rgba(255, 255, 255, 0.7);
}

.header {
    text-align: center;
    margin-bottom: 30px;
}

.tag {
    display: inline-block;
    background: #dbeafe;
    color: #1d4ed8;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 14px;
}

.header h1 {
    font-size: 44px;
    color: #0f172a;
    margin-bottom: 10px;
}

.header p {
    color: #475569;
    font-size: 18px;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto;
}

.feedback-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.input-group {
    display: flex;
    flex-direction: column;
    gap: 9px;
}

.input-group label {
    font-weight: 700;
    color: #1e293b;
    font-size: 16px;
}

input,
select,
textarea {
    width: 100%;
    padding: 14px 15px;
    border: 1px solid #cbd5e1;
    border-radius: 14px;
    outline: none;
    font-size: 16px;
    transition: all 0.3s ease;
    background: #f8fbff;
}

input:focus,
select:focus,
textarea:focus {
    border-color: #2563eb;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
}

textarea {
    resize: vertical;
    min-height: 150px;
}

.radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding-top: 4px;
}

.radio-group label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: #334155;
    cursor: pointer;
}

.radio-group input[type="radio"] {
    width: auto;
}

.checkbox-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #334155;
    font-size: 16px;
    cursor: pointer;
    margin-top: 4px;
}

.checkbox-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin: 0;
    accent-color: #2563eb;
    flex-shrink: 0;
}

.button-group {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-top: 10px;
}

.btn {
    border: none;
    padding: 14px 26px;
    border-radius: 14px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    transition: all 0.3s ease;
}

.submit-btn {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: white;
    box-shadow: 0 10px 22px rgba(37, 99, 235, 0.25);
}

.submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(37, 99, 235, 0.35);
}

.reset-btn {
    background: #e2e8f0;
    color: #0f172a;
}

.reset-btn:hover {
    background: #cbd5e1;
    transform: translateY(-2px);
}

.popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    display: none;
    justify-content: center;
    align-items: center;
    padding: 20px;
    z-index: 10;
}

.popup-overlay.show {
    display: flex;
}

.popup-card {
    width: 100%;
    max-width: 430px;
    background: white;
    border-radius: 22px;
    padding: 34px 28px;
    text-align: center;
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.18);
    animation: popupFade 0.3s ease;
}

.popup-icon {
    width: 70px;
    height: 70px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: #dcfce7;
    color: #16a34a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 34px;
    font-weight: 700;
}

.popup-card h2 {
    color: #0f172a;
    font-size: 30px;
    margin-bottom: 10px;
}

.popup-card p {
    color: #475569;
    line-height: 1.6;
    font-size: 16px;
}

.popup-line {
    margin-top: 10px;
    font-style: italic;
}

.popup-btn {
    margin-top: 20px;
    padding: 12px 28px;
    border: none;
    border-radius: 12px;
    background: #2563eb;
    color: white;
    font-weight: 700;
    cursor: pointer;
    font-size: 15px;
}

.popup-btn:hover {
    background: #1d4ed8;
}

@keyframes popupFade {
    from {
        opacity: 0;
        transform: scale(0.92);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

@media (max-width: 768px) {
    .row {
        grid-template-columns: 1fr;
    }

    .form-card {
        padding: 24px 18px;
    }

    .header h1 {
        font-size: 34px;
    }

    .header p {
        font-size: 16px;
    }

    .button-group {
        flex-direction: column;
    }

    .radio-group {
        gap: 14px;
    }
}


/*Script.js*/
const form = document.getElementById("feedbackForm");
const popup = document.getElementById("successPopup");

form.addEventListener("submit", function (event) {
    event.preventDefault();

    if (form.checkValidity()) {
        popup.classList.add("show");
        form.reset();
    } else {
        form.reportValidity();
    }
});

function closePopup() {
    popup.classList.remove("show");
}
